@model IEnumerable< RecursosHumanos_Models.Evaluacion>
@using RecursosHumanos_Utilidades
@using RecursosHumanos_Models
@model  RecursosHumanos_Models.ViewModels.HomeVM
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
    @if (User.IsInRole(WC.AdminRole))
        {
    <div class="container mt-5" id="contprincipal">
        
                     <h4 id="titulo-evaluaciones-pasadas">Evaluaciones Pasadas</h4>
        <div class="input-group mb-3">
            <input type="text" class="form-control" placeholder="Buscar Evaluación..." aria-label="Buscar Evaluación..." aria-describedby="button-addon2">
            <button class="btn btn-outline-secondary" type="button" id="btn-Eva">
                <i class="bi bi-search"></i>
            </button>
        </div>
        <div id="evaluaciones-pasadas" class="mb-4">
                <div class="row">
                    @foreach (var prop in Model.Evaluacion)
                    {
                        //Vsita pacial para Desplegar todos los productos ver concepto de vistas parciales
                        <partial name="_ProductoCard" model="prop" />

                    }
                </div>    <div id="card-body-Eva" class="card-body d-flex justify-content-between align-items-center">
                    <span id="titulo-evaluacion-1">Evaluación 1</span>
                    <div>
                        <button class="btn btn-ver-resultados" id="btn-Eva" aria-label="Ver resultados de Capacitación 1">Ver Resultados</button>
                        <button class="btn btn-eliminar" id="btn-eliminar-Eva" aria-label="Eliminar Capacitación 1">Eliminar</button>
                    </div>
                </div>
            </div>
            <div class="card mb-2" id="cartaEva">
                <div id="card-body-Eva" class="card-body d-flex justify-content-between align-items-center">
                    <span id="titulo-evaluacion-2">Evaluación 2</span>
                    <div>
                        <button class="btn btn-ver-resultados" id="btn-Eva" aria-label="Ver resultados de Capacitación 2">Ver Resultados</button>
                        <button class="btn btn-eliminar" id="btn-eliminar-Eva" aria-label="Eliminar Capacitación 2">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end mb-4">
            <a href="#" class="btn btn-primary btn-nueva-capacitacion" id="btn-Eva">Nueva Evaluación</a>
            </div>
            </div>
        }
        else if (User.IsInRole(WC.ClienteRole))
        {
            <div class="container mt-5" id="contenedor-secundario1">

                <h4 id="titulo-evaluaciones-pendientes">Evaluaciones Pendientes</h4>
                <div class="mb-4" id="contenedor-busqueda-pendientes">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="Buscar Evaluación Pendiente..." aria-label="Buscar Evaluación Pendiente..." aria-describedby="button-addon2">
                        <button class="btn btn-outline-secondary" type="button" id="btn-Eva">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>

                <div id="evaluaciones-pendientes" class="mb-4">
                    <div class="card mb-2" id="cartaEva">
                        <div id="card-body-Eva" class="card-body d-flex justify-content-between align-items-center">
                            <span id="titulo-evaluacion-pendiente-1">Evaluación Pendiente 1</span>
                            <button class="btn btn-realizar-evaluacion" id="btn-Eva" aria-label="Realizar Evaluación Pendiente 1">Realizar evaluación</button>
                        </div>
                    </div>
                    <div class="card mb-2" id="cartaEva">
                        <div id="card-body-Eva" class="card-body d-flex justify-content-between align-items-center">
                            <span id="titulo-evaluacion-pendiente-2">Evaluación Pendiente 2</span>
                            <button class="btn btn-realizar-evaluacion" id="btn-Eva" aria-label="Realizar Evaluación Pendiente 2">Realizar evaluación</button>
                        </div>
                    </div>
                </div>

            </div>

            <div class="container mt-5" id="contenedor-secundario1">

                <h4 id="titulo-evaluaciones-completadas">Evaluaciones Completadas</h4>
                <div class="mb-4" id="contenedor-busqueda-completadas">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="Buscar Evaluación Completada..." aria-label="Buscar Evaluación Completada..." aria-describedby="button-addon2">
                        <button class="btn btn-outline-secondary" type="button" id="btn-Eva">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </div>

                <div id="evaluaciones-completadas" class="mb-4">
                    <div class="card mb-2" id="cartaEva">
                        <div id="card-body-Eva" class="card-body">
                            <span id="titulo-evaluacion-completada-1">Evaluación Completada 1</span>
                            <button class="btn btn-realizar-evaluacion" id="btn-Eva" aria-label="Realizar Evaluación Pendiente 2">Ver mi evaluación</button>
                        </div>
                    </div>
                    <div class="card mb-2" id="cartaEva">
                        <div id="card-body-Eva" class="card-body">
                            <span id="titulo-evaluacion-completada-2">Evaluación Completada 2</span>
                            <button class="btn btn-realizar-evaluacion" id="btn-Eva" aria-label="Realizar Evaluación Pendiente 2">Ver mi evaluación</button>
                        </div>
                    </div>
                </div>
            </div>

        }

       


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>